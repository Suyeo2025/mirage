[Unit]
Description=Mirage Client (SOCKS5 Proxy)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/opt/mirage/mirage-client \
    --server sla.sunlawai.com \
    --psk CHANGE_ME \
    --listen 0.0.0.0:1080
Restart=always
RestartSec=3
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
